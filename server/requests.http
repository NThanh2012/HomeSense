
@baseUrl = http://localhost:3001
@token = your_access_token_here
@userToken = your_user_access_token_here
@adminToken = your_admin_access_token_here
@userId = replace_with_user_id
@intentId = replace_with_intent_id
@learningJobId = replace_with_learning_job_id
@matchId = replace_with_match_id

# Manual HTTP smoke collection for the running backend.
# Replace the variables above, then run each request with a REST Client.
# Automated Jest coverage remains in src/**/*.spec.ts and runs with `corepack pnpm test`.

