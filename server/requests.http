# ==========================================
# USER-BEHAVIORS ENDPOINTS
# ==========================================

### POST /user-behaviors
POST {{baseUrl}}/user-behaviors
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
    "eventType": "SEARCH",
    "keyword": "can ho cho thue gan truong",
    "filters": {
        "transactionType": "RENT",
        "propertyType": "APARTMENT",
        "district": "Cau Giay"
    },
    "metadata": {
        "source": "requests-http-synthetic"
    },
    "eventKey": "requests-http-search-001"
}

### POST /user-behaviors weak view - expect low-priority micro-batch
POST {{baseUrl}}/user-behaviors
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
    "eventType": "RECOMMENDATION_VIEW",
    "keyword": "can ho",
    "eventKey": "requests-http-view-001"
}

### POST /user-behaviors invalid eventType - expect { code, message } error
POST {{baseUrl}}/user-behaviors
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
    "eventType": "INVALID_EVENT_TYPE"
}

### POST /user-behaviors without token - expect auth error
POST {{baseUrl}}/user-behaviors
Content-Type: application/json

{
    "eventType": "SEARCH",
    "keyword": "synthetic unauthorized request"
}

