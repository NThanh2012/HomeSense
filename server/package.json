{
    "name": "api",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "build": "nest build",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:prod": "node dist/main.js",
        "prisma:generate": "prisma generate --schema src/database/prisma/schema.prisma",
        "prisma:migrate": "prisma migrate dev --schema src/database/prisma/schema.prisma",
        "prisma:migrate:deploy": "prisma migrate deploy --schema src/database/prisma/schema.prisma",
        "prisma:studio": "prisma studio --schema src/database/prisma/schema.prisma"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.0.1",
        "@nestjs/mapped-types": "^2.1.0",
        "@nestjs/mongoose": "^11.0.3",
        "@nestjs/platform-express": "^11.0.1",
        "@prisma/client": "^6.19.2",
        "bcryptjs": "^3.0.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "mongoose": "^8.20.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.10.7",
        "jest": "^30.0.0",
        "prisma": "^6.19.2",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "roots": [
            "<rootDir>/test"
        ],
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": [
                "ts-jest",
                {
                    "tsconfig": "tsconfig.spec.json"
                }
            ]
        },
        "testEnvironment": "node"
    }
}
